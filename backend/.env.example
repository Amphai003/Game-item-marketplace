# Server configuration
PORT=3000

# Database
# Local docker-compose Postgres (see docker-compose.yml). Override in your own .env.
DATABASE_URL=postgresql://postgres:password@localhost:5432/game_item_marketplace

# Search Engine (Meilisearch)
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=masterKey123!

# Authentication
JWT_SECRET=replace_with_a_secure_random_key_in_production
JWT_EXPIRATION=7d

# Discord OAuth (Optional/Recommended for Gaming Communities)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# File Storage (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=game-marketplace-items
